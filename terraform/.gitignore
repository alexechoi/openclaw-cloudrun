# Terraform state files
*.tfstate
*.tfstate.*

# Terraform lock file (can be committed, but often ignored)
.terraform.lock.hcl

# Terraform directory
.terraform/

# Variable files with secrets
*.tfvars
!terraform.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# Plan output files
*.tfplan
