# OS / editor noise
.DS_Store
**/.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Local env files (never commit)
.env
.env.*
!.env.example

# Terraform local state -- store remote backend or treat as sensitive.
# tfstate files contain provider tokens and deployment metadata.
**/.terraform/
**/terraform.tfstate
**/terraform.tfstate.backup
**/terraform.tfstate.*.backup
**/.terraform.lock.hcl
**/terraform.tfvars

# Local gcloud config / credentials
.gcloud/
**/credentials.json
**/service-account*.json
