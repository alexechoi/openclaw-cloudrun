# Cloud Build ignore file
# This overrides .gitignore for Cloud Build uploads

# Include files that are in .gitignore but needed for Docker builds:
# - pnpm-lock.yaml is needed but gitignored locally

# Exclude large directories not needed for builds
.git/
.worktrees/
node_modules/
**/node_modules/
.pnpm-store/
**/.pnpm-store/

# Exclude build artifacts
dist/
**/dist/
coverage/
**/coverage/

# Exclude media files
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.mp4
*.mov
*.wav
*.mp3

# Exclude platform-specific directories
apps/macos/.build/
apps/ios/build/
**/*.trace

# Exclude other large directories
Peekaboo/
Swabble/
Core/
vendor/

# Exclude temp files
.DS_Store
**/.DS_Store
*.log
tmp/
**/tmp/
.bun-cache/
.bun/
.tmp/
**/.tmp/
